# Orchestrator — Environment Variables
# Copy this file to .env, fill in real values, then: source .env
# Or export each variable individually in ~/.zshrc
#
# .env is gitignored — never commit real keys.

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# MiniMax API (code generation + council task generation)
# Get key at: platform.minimax.io → API Keys
MINIMAX_API_KEY=your-minimax-api-key-here

# Discord bot token
# Get at: discord.com/developers/applications → your app → Bot → Token
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# Discord channel IDs (right-click channel → Copy Channel ID; needs Dev Mode on)
DISCORD_CHANNEL_LIVE=123456789012345678
DISCORD_CHANNEL_BLOCKED=123456789012345678
DISCORD_CHANNEL_CHAT=123456789012345678
DISCORD_CHANNEL_METRICS=123456789012345678

# Your Discord user ID — bot silently ignores anyone else
# Right-click your username → Copy User ID (needs Dev Mode on)
DISCORD_USER_ID=123456789012345678

# ── OPTIONAL TUNING ───────────────────────────────────────────────────────────

# Local dashboard port (default: 8080)
DASHBOARD_PORT=8080

# How often to post metrics snapshot to #orchestrator-metrics, in hours (default: 10)
METRICS_INTERVAL_HOURS=10

# Council task generation creativity (0.5=focused, 0.75=default, 1.0=creative)
COUNCIL_TEMPERATURE=0.75

# ── FALLBACK NOTIFICATIONS (all optional) ────────────────────────────────────
# Used when Discord is unavailable. Priority order: ntfy → email → macOS.

# ntfy.sh push notifications (free, works on mobile, no account needed)
# Setup: ntfy.sh — pick a unique topic name
NTFY_TOPIC=

# Email via SMTP (e.g. Gmail with an app password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=
