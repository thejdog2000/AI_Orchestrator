# Secrets — never commit
.env
*.env
.env.*
# Template with placeholder values — safe and useful to commit
!.env.example

# Runtime state — regenerated on each run
orchestrator.db
orchestrator.db-shm
orchestrator.db-wal
orchestrator.db-journal
orchestrator.pid
.bot.pid
logs/
pending_review/
dashboard/
approved/
backups/
sprint_state.json
pause_state.json
CONTEXT_STALE

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/

# macOS / sandbox artifacts
.DS_Store
.AppleDouble
.fuse_hidden*

# Editor
.vscode/
.idea/
*.swp
*.swo

# Node (for lang pipeline smoke tests)
node_modules/

# Runtime output dirs — don't track generated/operational content
backups/
approved/

# tasks/ — keep lang_schedule.json (config), ignore generated/seed files
tasks/orchestrator_review_tasks.json

# git_watcher IPC — written by Claude, consumed by git_watcher.py on your Mac
COMMIT_REQUEST.txt
.git_watcher.pid

# Keep generated dashboard HTML so you can open it without running the orchestrator
# (comment out if you don't want it tracked)
# dashboard/index.html

# Stale orphan — authoritative copy is agents/personas/ (delete this dir from Finder)
personas/

# macOS clipboard artifact — safe to delete from Finder
ORCHESTRATOR_CONTEXT.textClipping

# SQLite WAL/journal artifacts
orchestrator.db-journal
orchestrator.db-wal
orchestrator.db-shm
